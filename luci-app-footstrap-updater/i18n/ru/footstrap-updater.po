#: htdocs/luci-static/resources/fs-update.js:158
msgid "Cancel"
msgstr "Отмена"

#: htdocs/luci-static/resources/fs-update.js:138
msgid "Close"
msgstr "Закрыть"

#: htdocs/luci-static/resources/fs-update.js:152
msgid ""
"Download and install the latest Footstrap release from GitHub? The page "
"reloads when done."
msgstr ""
"Скачать и установить последний выпуск Footstrap с GitHub? По завершении "
"страница перезагрузится."

#: htdocs/luci-static/resources/fs-update.js:214
msgid "Downloading and installing…"
msgstr "Загрузка и установка…"

#: root/usr/share/rpcd/acl.d/luci-app-footstrap-updater.json:3
msgid "Footstrap theme self-update (install the latest release)"
msgstr "Самообновление темы Footstrap (установка последнего выпуска)"

#: htdocs/luci-static/resources/fs-update.js:166
msgid "Loading release notes…"
msgstr "Загрузка примечаний к выпуску…"

#: htdocs/luci-static/resources/fs-update.js:185
msgid "Log in again"
msgstr "Войти снова"

#: htdocs/luci-static/resources/fs-update.js:154
msgid "Release notes:"
msgstr "Примечания к выпуску:"

#: htdocs/luci-static/resources/fs-update.js:151
msgid ""
"This release may contain breaking changes — read the notes below before "
"updating."
msgstr ""
"Этот выпуск может содержать несовместимые изменения — прочитайте примечания "
"ниже перед обновлением."

#: htdocs/luci-static/resources/fs-update.js:159
msgid "Update"
msgstr "Обновить"

#: htdocs/luci-static/resources/fs-update.js:131
msgid "Update Footstrap"
msgstr "Обновление Footstrap"

#: htdocs/luci-static/resources/fs-update.js:137
msgid "Update failed"
msgstr "Не удалось обновить"

#: htdocs/luci-static/resources/fs-update.js:181
msgid ""
"Update installed. The router restarted its session service, so you have been "
"logged out — sign in again to load the new theme."
msgstr ""
"Обновление установлено. Роутер перезапустил службу сессий, поэтому сеанс "
"завершён — войдите снова, чтобы загрузить новую тему."

#: htdocs/luci-static/resources/fs-update.js:198
msgid "Updated. Reloading…"
msgstr "Обновлено. Перезагрузка…"

#: htdocs/luci-static/resources/fs-update.js:191
msgid "timed out waiting for the installer"
msgstr "истекло время ожидания установщика"

#: htdocs/luci-static/resources/fs-update.js:137
msgid "unknown error"
msgstr "неизвестная ошибка"
