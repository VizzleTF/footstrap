#!/bin/sh

# HAVE WE BEEN INSTALLED BEFORE?
#
# The rule is: a FRESH install may make its sidebar layout the active theme; an
# UPGRADE must never change whatever theme the user is currently using. That was
# expressed as `[ "$PKG_UPGRADE" = 1 ]`, and in production PKG_UPGRADE is never set
# — apk does not export it and the package's postinst does not either, so only
# dev-sync.sh (which sets it by hand) ever took the upgrade branch. On a real router
# the guard was dead, and an upgrade that happened to find an empty mediaurlbase
# would activate this theme behind the user's back.
#
# A marker file on the rootfs is the state that actually distinguishes the two:
# it exists if and only if this script has completed at least once.
FS_MARKER=/usr/share/luci-theme-footstrap/.installed
if [ "$PKG_UPGRADE" = 1 ] || [ -f "$FS_MARKER" ]; then
	PKG_UPGRADE=1
else
	PKG_UPGRADE=0
fi

# Remove any previously registered footstrap theme entries. Older versions
# registered six dark/light variants — mode (dark/light) and palette are now
# client-side toggles (Appearance popover), so only the layout needs a
# server-side theme entry.
for t in Footstrap FootstrapDark FootstrapLight FootstrapTop FootstrapTopDark \
         FootstrapTopLight FootstrapSidebar FootstrapOnTop; do
	uci -q delete "luci.themes.$t"
done

# Register the two layouts.
uci set luci.themes.FootstrapSidebar=/luci-static/footstrap
uci set luci.themes.FootstrapOnTop=/luci-static/footstrap-top

# Normalise the active theme. The six pre-consolidation media paths below are
# neither registered in luci.themes nor present on disk any more: an install left
# pointing at one is stranded on a theme the Design page does not list, so it
# cannot be switched away from through the UI, and its media dir 404s. Map each
# explicitly onto its surviving layout; the trailing glob then catches any other
# footstrap-* path (typo, future variant). This runs before the on-disk check
# below, so a migrated path is never mistaken for a missing theme. Non-footstrap
# themes are left untouched, and a fresh install defaults to the sidebar layout.
cur=$(uci -q get luci.main.mediaurlbase)
new=$cur
case "$cur" in
	# legacy six -> two layouts
	/luci-static/footstrap-top|\
	/luci-static/footstrap-top-dark|\
	/luci-static/footstrap-top-light) new=/luci-static/footstrap-top ;;
	/luci-static/footstrap|\
	/luci-static/footstrap-dark|\
	/luci-static/footstrap-light)     new=/luci-static/footstrap ;;
	# anything else footstrap-ish
	/luci-static/footstrap-top*)      new=/luci-static/footstrap-top ;;
	/luci-static/footstrap*)          new=/luci-static/footstrap ;;
	"") [ "$PKG_UPGRADE" = 1 ] || new=/luci-static/footstrap ;;
esac

# Last-resort guard against a blank UI: whatever stays active must actually be on
# disk — both its media dir and its ucode template. If a partial upgrade or a
# hand-edited mediaurlbase points at neither, fall back to the stock bootstrap
# theme; a plain UI beats no UI. Skipped when bootstrap itself is not installed.
theme=${new##*/}
if [ -n "$theme" ] && { [ ! -d "/www/luci-static/$theme" ] ||
                        [ ! -f "/usr/share/ucode/luci/template/themes/$theme/header.ut" ]; }; then
	[ -d /www/luci-static/bootstrap ] && new=/luci-static/bootstrap
fi

[ "$new" = "$cur" ] || uci set luci.main.mediaurlbase="$new"

uci commit luci

# the dispatch/menu caches embed theme paths — drop them so the switch applies on
# the next request rather than after a reboot
rm -f /tmp/luci-indexcache* 2>/dev/null
rm -rf /tmp/luci-modulecache 2>/dev/null

# Drop the marker LAST, so a run that dies half-way is still treated as a fresh
# install next time rather than as an upgrade.
mkdir -p "$(dirname "$FS_MARKER")" 2>/dev/null
: > "$FS_MARKER" 2>/dev/null

exit 0
