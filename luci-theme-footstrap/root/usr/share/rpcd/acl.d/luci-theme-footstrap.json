{
	"luci-theme-footstrap": {
		"description": "Footstrap Appearance router-wide defaults (Save as default) and login background upload",
		"write": {
			"ubus": { "uci": [ "set", "commit" ], "file": [ "remove", "exec" ] },
			"uci": [ "footstrap" ],
			"cgi-io": [ "upload" ],
			"file": {
				"/etc/footstrap/login-bg": [ "write", "remove" ],
				"/bin/chmod 644 /etc/footstrap/login-bg": [ "exec" ]
			}
		}
	}
}
